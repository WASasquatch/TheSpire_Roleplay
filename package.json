{
  "name": "thekeep",
  "private": true,
  "version": "0.0.0",
  "description": "The Spire - a roleplay-focused chat system",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "db:push": "pnpm --filter @thekeep/server run db:push",
    "db:studio": "pnpm --filter @thekeep/server run db:studio",
    "ship": "bash scripts/ship.sh",
    "deploy": "bash scripts/ship.sh --deploy-only",
    "bump:patch": "bash scripts/bump.sh patch",
    "bump:minor": "bash scripts/bump.sh minor",
    "bump:major": "bash scripts/bump.sh major"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "typescript": "^5.6.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.11",
      "@types/react-dom": "^18.3.0"
    }
  }
}
