# Development defaults. Copy to .env, fill SESSION_SECRET, and `pnpm dev`.
# In production these are typically set as env vars by the host (see fly.toml).

# Server port. Dev: 3001 (Vite proxies /api routes here from :5173).
# Prod (Fly.io): 8080 — Fly's edge handles external 80/443 → internal 8080.
PORT=3001

# Sqlite path. Relative to apps/server/. In prod we use an absolute path on a
# mounted volume (see fly.toml: /data/thekeep.sqlite). DATABASE_URL also
# works as a fallback if you already have it set in an older local .env.
SQLITE_PATH=./data/thekeep.sqlite

# Required. Min 32 chars. Generate with `openssl rand -hex 32`.
SESSION_SECRET=change-me-to-a-32+-char-random-string-please

# CORS allow-list. Dev: the Vite dev-server origin. Prod: empty string —
# the web bundle is served from the same origin as the API so CORS is moot.
WEB_ORIGIN=http://localhost:5173

# pino log level: trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# NODE_ENV=production triggers static-file serving + SPA fallback inside the
# server (see apps/server/src/index.ts). In dev we leave it unset so Vite
# handles the SPA on :5173.
# NODE_ENV=production
