{
  "name": "thekeep",
  "private": true,
  "version": "0.33.19",
  "description": "The Spire - a roleplay-focused chat system",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:push": "pnpm --filter @thekeep/server run db:push",
    "db:studio": "pnpm --filter @thekeep/server run db:studio",
    "i18n:coverage": "node scripts/i18n-coverage.mjs",
    "ship": "bash scripts/ship.sh",
    "deploy": "bash scripts/ship.sh --deploy-only",
    "bump:patch": "bash scripts/bump.sh patch",
    "bump:minor": "bash scripts/bump.sh minor",
    "bump:major": "bash scripts/bump.sh major"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-i18next": "^6.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.9.4",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.63.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.11",
      "@types/react-dom": "^18.3.0"
    }
  }
}
