# =====================================================================
# Dependencies
# =====================================================================
node_modules/
.pnpm-store/
.yarn/
.npm/

# =====================================================================
# Build output
# =====================================================================
dist/
build/
out/
*.tsbuildinfo

# Vite SPA bundle (regenerated by `pnpm --filter @thekeep/web run build`)
apps/web/dist/

# =====================================================================
# Environment / secrets — NEVER commit these
# =====================================================================
# Keep .env.example as the public template; ignore everything else that
# matches `.env` family. The negation lines preserve any *.example variant.
.env
.env.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.staging
.env.test
.env.test.local
!.env.example
!*.env.example

# Standalone secret material — TLS keys, signed cookies, OAuth blobs, etc.
*.pem
*.key
*.p12
*.pfx
secrets/

# Ad-hoc local API probes at the repo root. These routinely hardcode a real
# API key/secret for a quick test (e.g. test_youtube_playlist_scrape.py), so
# they must NEVER be committed. If a key ever lands here, rotate it.
/test_*.py

# =====================================================================
# Server-side runtime data
# =====================================================================
# The SQLite file contains argon2 password hashes, session ids, message
# history, and admin/user PII. Ignore the whole data directory plus any
# sqlite artifact anywhere in the tree as belt-and-suspenders.
apps/server/data/
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.sqlite-journal
*.sqlite.gz
*.db
*.db-shm
*.db-wal

# Detached-process pidfiles + ad-hoc backups, plus the local backups/ dir
# (DB + disk snapshots pulled from prod — keep them out of git AND the repo root).
*.pid
*.bak
*.backup
/backups/

# =====================================================================
# Logs
# =====================================================================
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
lerna-debug.log*

# =====================================================================
# Caches & test artifacts
# =====================================================================
.cache/
.turbo/
.vite/
.parcel-cache/
.eslintcache
coverage/
*.lcov
.nyc_output/

# Vite bundle analyzer output (only emitted when ROLLUP_INSPECT=1)
stats.html

# =====================================================================
# Editor / IDE
# =====================================================================
# .vscode is allowed to ship shared recommendations / launch configs but
# nothing user-specific (settings.json, *.code-workspace).
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.swp
*.swo

# Claude Code per-project config (tool permissions, hooks, agents). Local
# to each developer; not shared via the repo. If the team ever wants to
# ship a baseline `.claude/settings.json`, allow-list it here with `!`.
.claude/
*~
.history/
.DS_Store
Thumbs.db
Desktop.ini

# =====================================================================
# Misc
# =====================================================================
# Local-only fly state.
.fly/
fly.toml.local

# tmp scratch dirs developers sometimes create at the project root
/tmp/
/scratch/

# Ad-hoc shell scripts dropped at the repo root for one-shot codemods or
# personal dev launchers. Prefix with `.tmp-` and they'll stay local —
# anything worth keeping should graduate to scripts/.
/.tmp-*

# Windows NTFS Alternate Data Stream sidecars left behind by files
# downloaded from a browser and copied through the WSL bridge. Pure
# metadata, useless on disk.
*:Zone.Identifier

# Local-only security audit notes — findings, exploit paths, status of
# each item. Useful as a working doc but not for the public repo (avoid
# advertising live issues to attackers).
SECURITY-AUDIT.md
SECURITY-NOTES.md

# Local-only working doc tracking in-flight feature scope across sessions.
plan.md
plan_ext.md
plan_patch.md
plan_minor.md
plan_major.md

# Scratchpad for in-progress commit messages drafted between sessions.
commit.md

# Running ELI5 "what's new" log for end users (dated entries). Local-only;
# never cleared by deploy, unlike commit.md.
updates.md
